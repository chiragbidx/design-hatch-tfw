# Database
DATABASE_URL="postgresql://user:password@localhost:5432/panda_upwork?schema=public"

# Authentication
AUTH_SECRET="replace-with-secure-random-string"

# Public URLs
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Stripe payments
STRIPE_SECRET_KEY="sk_test_yoursecretkey"
STRIPE_PUBLISHABLE_KEY="pk_test_yourpublickey"
STRIPE_WEBHOOK_SECRET="whsec_yourwebhooksecret"
STRIPE_CURRENCY="usd"

# Email (SendGrid)
SENDGRID_API_KEY="SG.your-sendgrid-api-key"
SENDGRID_FROM_EMAIL="noreply@pandawork.com"

# File storage
STORAGE_REGION="auto"
STORAGE_ENDPOINT="https://storage.example.com"
STORAGE_ACCESS_KEY="your-storage-access-key"
STORAGE_SECRET_KEY="your-storage-secret-key"
STORAGE_BUCKET_NAME="project-uploads"

# Platform settings
PLATFORM_FEE_PERCENT="10"
